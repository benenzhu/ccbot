# Platform selection: "telegram" (default) or "feishu"
CCBOT_PLATFORM=telegram

# --- Telegram Backend (CCBOT_PLATFORM=telegram) ---
# Telegram Bot Token (required for telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Allowed user IDs (comma-separated, required)
# For Telegram: numeric user IDs (e.g. 123456789)
ALLOWED_USERS=123456789,987654321

# --- Feishu Backend (CCBOT_PLATFORM=feishu) ---
# Feishu App credentials (required for feishu)
# FEISHU_APP_ID=cli_xxxx
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_ENCRYPT_KEY=your_encrypt_key
# FEISHU_VERIFICATION_TOKEN=your_verification_token
# FEISHU_DOMAIN=feishu  # "feishu" for feishu.cn, "lark" for larksuite.com
# For Feishu: open_id strings (e.g. ou_xxxx)
# ALLOWED_USERS=ou_xxxx,ou_yyyy

# --- Common Settings ---
# Tmux session name (optional, defaults to "ccbot")
TMUX_SESSION_NAME=ccbot

# Claude command to run in new windows (optional, defaults to "claude")
CLAUDE_COMMAND=claude

# Monitor polling interval in seconds (optional, defaults to 2.0)
MONITOR_POLL_INTERVAL=2.0
